{
  "name": "requiredfilings-site",
  "version": "1.0.0",
  "private": true,
  "description": "RequiredFilings.com — flat HTML site with production minification pipeline",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:clean": "node scripts/build.mjs --clean",
    "validate": "html-validate \"required-filings/**/*.html\"",
    "validate:dist": "html-validate \"dist/**/*.html\"",
    "preview": "node scripts/preview.mjs",
    "deploy:zip": "powershell -ExecutionPolicy Bypass -File ./build-deploy-zip.ps1"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "html-validate": "^11.5.6",
    "svgo": "^4.0.2",
    "terser": "^5.49.0"
  }
}
